# Copy this to .env at the repo root, then run:
#   sudo ./bare-metal/setup.sh
#
# Alternatively, pass NICs as arguments:
#   sudo ./bare-metal/setup.sh enp1s0 enp2s0

# Required: physical NICs that face each endpoint host
EARTH_IFACE=enp1s0
MARS_IFACE=enp2s0

# Addresses shown in the dashboard. EARTH_IP_MARS / EARTH_IP_MOON are
# Earth's per-link IPs (e.g. Earth has 192.168.2.1 on the Mars link and
# 192.168.1.1 on the Luna link). MOON_LABEL renames the second link
# (default LUNAR for bare-metal). HIDE_CUSTOM hides the Custom section
# entirely from the UI.
#EARTH_IP=192.168.2.1
#EARTH_IP_MARS=192.168.2.1
#EARTH_IP_MOON=192.168.1.1
#MARS_IP=192.168.2.2
#MOON_IP=192.168.1.2
#MOON_LABEL=LUNAR
#HIDE_CUSTOM=1

# Optional: 802.1Q VLAN IDs (1-4094).
# If set, boot.sh creates a VLAN sub-interface (e.g., enp1s0.2) and the
# delaybox pcaps against it instead of the raw NIC. The switch-side port
# must be a trunk delivering the tagged VLAN.
# Use this when you want the delay box to receive Earth traffic on VLAN 2
# and Mars traffic on VLAN 3, etc.
#EARTH_VLAN=2
#MARS_VLAN=3

# Optional: enable Earth↔Moon link (requires 2 more NICs)
#MOON_SRC_IFACE=enp3s0
#MOON_IFACE=enp4s0
#MOON_SRC_VLAN=
#MOON_VLAN=

# Optional: enable Earth↔Custom link
#CUSTOM_SRC_IFACE=enp5s0
#CUSTOM_IFACE=enp6s0
#CUSTOM_SRC_VLAN=
#CUSTOM_VLAN=

# Optional: initial delays (seconds). Editable at runtime via dashboard/Redis.
#DELAY_EARTH_TO_MARS=10
#DELAY_MARS_TO_EARTH=10
#DELAY_EARTH_TO_MOON=1.28
#DELAY_MOON_TO_EARTH=1.28
#DELAY_EARTH_TO_CUSTOM=5
#DELAY_CUSTOM_TO_EARTH=5
